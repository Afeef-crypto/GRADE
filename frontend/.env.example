# GRADE — Vite frontend
#
# Copy to `.env` or `.env.local` in this folder (same level as package.json).
# Only variables prefixed with VITE_ are exposed to the browser.

# When the UI is opened as a static build or from a host without the dev proxy,
# set the public API base URL (no trailing slash). Dev server with default proxy
# can leave this unset.
# VITE_API_URL=http://127.0.0.1:8000
