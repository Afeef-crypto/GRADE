# =============================================================================
# GRADE — backend / API environment template
#
# 1. Copy this file to `.env` in the repository root (same folder as pyproject.toml).
# 2. Fill in at least GOOGLE_APPLICATION_CREDENTIALS (or GOOGLE_CLOUD_VISION_API_KEY).
# Answer keys: JSON or text-based PDF (numbered 1. 2. …) via POST /upload/key/file + form exam_id.
# 3. Start the API from the repo root so `.env` is found:
#      $env:PYTHONPATH="src"
#      python -m uvicorn autograder.api:app --host 127.0.0.1 --port 8000
#
# If you installed the `api` extra, `python-dotenv` loads `.env` automatically when the
# app module is imported. Without it, set variables in PowerShell / System Properties.
# =============================================================================

# --- Google Cloud Vision (service account JSON — recommended on Windows) ---
# Download the JSON key from Cloud Console → IAM → Service account → Keys → Add key → JSON.
# Use a normal GCP project with **Cloud Vision API** enabled. Keys tied only to `gen-lang-client-*`
# / Gemini-only flows may return ACCOUNT_STATE_INVALID for Vision — create a dedicated project + SA.
# In .env files, prefer forward slashes so backslashes are not treated as escapes:
#   GOOGLE_APPLICATION_CREDENTIALS=C:/Users/YourName/AppData/Local/secrets/vision-sa.json
# Or wrap in quotes if you use backslashes:
#   GOOGLE_APPLICATION_CREDENTIALS="C:\Users\YourName\secrets\vision-sa.json"
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: API key instead of JSON (REST client path in google-cloud-vision)
# GOOGLE_CLOUD_VISION_API_KEY=
#
# pip install google-cloud-vision   or   pip install -e ".[ocr_google]"
# OCR uses DOCUMENT_TEXT_DETECTION (handwriting-friendly) as tier 1 before PaddleOCR / TrOCR.
# Optional: use Application Default Credentials (e.g. gcloud auth application-default login)
# GRADE_GOOGLE_VISION_USE_ADC=true
# Optional: only Google for cloud tier (no Azure fallback if Vision fails)
# GRADE_OCR_GOOGLE_ONLY=true
# Optional: only cloud OCR — no local PaddleOCR / TrOCR fallback
# GRADE_OCR_CLOUD_ONLY=true
#
# OCR quality (Google / Azure cloud tier — see prepare_image_for_cloud_ocr in autograder/ocr.py):
# GRADE_OCR_PATCH_SIZE=768          # preprocess resize before OCR (default 384 if unset; 768–1024 helps handwriting)
# GRADE_PDF_RENDER_SCALE=3.5        # PDF raster zoom in preprocess (default 3.0 in code if unset)
# GRADE_OCR_ENHANCE_CLOUD=1         # CLAHE contrast (default on; set 0 to disable)
# GRADE_OCR_CLOUD_UPSCALE=1         # Upscale small patches before Vision (default on; set 0 to disable)
# GRADE_OCR_CLOUD_MIN_MAX_DIM=1600  # Target min long edge in pixels (before Vision)
# GRADE_OCR_CLOUD_MAX_MAX_DIM=4096  # Cap long edge (Vision limit)
# GRADE_OCR_INPAINT_GREY_REDACTIONS=1  # Off unless set — inpaints flat grey (redactions); can damage lined paper / faint ink
# GRADE_OCR_FULL_PAGE=1             # API: OCR whole page once (no contour crops; fewer clipped sentence endings)
# GRADE_OCR_BBOX_PADDING_FRAC=0.06  # Expand each contour box before crop (default 0.04 in code; script uses 0.06)
# GRADE_OCR_BBOX_PADDING_PX_MIN=20
# GRADE_OCR_VISION_USE_PLAIN_TEXT=1 # Use Vision's flat .text instead of geometry-sorted blocks (compare if order looks wrong)

# --- CORS (optional) ---
GRADE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# --- LLM grading — Google Gemini (optional) ---
# pip install google-generativeai   or   pip install -e ".[llm_gemini]"
# Create a key in Google AI Studio (https://aistudio.google.com/apikey). Never commit it.
# If you ever paste a key in chat or source control, revoke it and create a new one.
GRADE_ENABLE_LLM=
# When LLM is enabled, default model is gemini-2.0-flash if unset:
# GRADE_LLM_MODEL=gemini-2.0-flash
GRADE_GEMINI_API_KEY=
# Alternative name (same effect):
# GEMINI_API_KEY=
# Tests / CI only — JSON matching EvaluationResult (see autograder.schemas):
# GRADE_LLM_MOCK_RESPONSE=

# --- Azure AI Vision (optional) ---
# AZURE_VISION_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
# AZURE_VISION_KEY=

# --- Postgres / Supabase (pgvector) — required for the API and tests ---
# Set a PostgreSQL URI (local Docker: docker compose up -d, then use the URL below).
# Install drivers: pip install -e ".[api]" (includes psycopg + pgvector) or pip install -e ".[postgres]"
# Apply SQL in supabase/migrations/ in order (Dashboard → SQL), or: supabase db push
# Use the pooled URI for server apps (Dashboard → Connect → transaction pooler, port 6543).
# GRADE_DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# If Windows/Python cannot resolve the DB host but nslookup returns an IP, bypass DNS:
# GRADE_DATABASE_HOSTADDR=2406:da14:...   # or an IPv4 from nslookup -type=A
# Local pytest default (docker-compose.yml): postgresql://grade:grade@127.0.0.1:5433/grade_test
# Override test DB only: GRADE_TEST_DATABASE_URL=postgresql://...
# If the password contains $ characters, quote the whole URL or rely on repo loaders that use
# interpolate=False (see autograder.api and scripts/verify_postgres_db.py).
# (DATABASE_URL is accepted as an alias.)
# Smoke-test Postgres: PYTHONPATH=src python scripts/verify_postgres_db.py
# Answer-key PDFs: PYTHONPATH=src python scripts/verify_key_pdfs.py

# --- Runtime ---
# PYTHONPATH=src
